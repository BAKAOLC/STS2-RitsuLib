<Project>
    <!--
        RitsuLib API compatibility defines.

        Generates a cumulative set of `STS2_AT_LEAST_<ver>` symbols based on the active
        `Sts2ApiCompat` value. Each symbol represents "the host API is at least this version".
        Source code expresses version-conditional logic as ranges:

            #if !STS2_AT_LEAST_0_104_0
            #if STS2_AT_LEAST_0_104_0
            #if !STS2_AT_LEAST_0_105_0

        Adding a new supported API version requires touching this file only:
        - append the version to `_RitsuLibSupportedApiVersions`
        - add a new DefineConstants entry for the new `STS2_AT_LEAST_*` symbol
        Existing #if branches across the codebase keep working without modifying old version ranges.
    -->

    <PropertyGroup>
        <_RitsuLibSupportedApiVersions>0.103.2;0.106.1;0.107.0;0.107.1;0.108.0;0.109.0</_RitsuLibSupportedApiVersions>
        <_RitsuLibSupportedApiList>|0.103.2|0.106.1|0.107.0|0.107.1|0.108.0|0.109.0|</_RitsuLibSupportedApiList>
    </PropertyGroup>

    <PropertyGroup>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.103.2'))">$(DefineConstants);STS2_AT_LEAST_0_103_2</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.104.0'))">$(DefineConstants);STS2_AT_LEAST_0_104_0</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.105.0'))">$(DefineConstants);STS2_AT_LEAST_0_105_0</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.105.1'))">$(DefineConstants);STS2_AT_LEAST_0_105_1</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.106.0'))">$(DefineConstants);STS2_AT_LEAST_0_106_0</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.106.1'))">$(DefineConstants);STS2_AT_LEAST_0_106_1</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.107.0'))">$(DefineConstants);STS2_AT_LEAST_0_107_0</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.107.1'))">$(DefineConstants);STS2_AT_LEAST_0_107_1</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.108.0'))">$(DefineConstants);STS2_AT_LEAST_0_108_0</DefineConstants>
        <DefineConstants Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(Sts2ApiCompat)', '0.109.0'))">$(DefineConstants);STS2_AT_LEAST_0_109_0</DefineConstants>
    </PropertyGroup>

    <Target Name="ValidateRitsuLibCompatTarget" BeforeTargets="CoreCompile">
        <Error
            Condition="'$(Sts2ApiCompat)' == '' or !$(_RitsuLibSupportedApiList.Contains('|$(Sts2ApiCompat)|'))"
            Text="Sts2ApiCompat='$(Sts2ApiCompat)' is not in the supported set ($(_RitsuLibSupportedApiVersions)). Update build\RitsuLib.CompatDefines.targets to add the new version and a corresponding STS2_AT_LEAST_* define."/>
    </Target>
</Project>
